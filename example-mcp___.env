# =============================================================================
# .env.example — PyFundaments + Universal MCP Hub
# Copyright 2026 - Volkan Kücükbudak
# Apache License V. 2 + ESOL 1.1
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env
#   2. Fill in the values you need
#   3. NEVER commit .env to version control!
#
# FUNDAMENTS RULES:
#   - Fundament keys are NEVER commented out — leave defaults if unused!
#   - App/* keys (LLM, Search, etc.) can be commented out freely.
#   - No key = no tool = no crash. Server always starts with fewer tools.
# =============================================================================


# =============================================================================
# SECTION 1 — PyFundaments Core (Guardian)
# WARNING: Never comment out fundament keys — leave defaults if unused!
# =============================================================================

# --- Database (postgresql.py) ---
# Full DSN for PostgreSQL. Works for local and cloud (Neon, Supabase, etc.)
# Neon example:  postgresql://user:pass@host.neon.tech/neondb?sslmode=require
# Local example: postgresql://user:pass@localhost:5432/mydb
# Leave default if your app does not need a database.
DATABASE_URL="your_database_dsn_here"

# --- Encryption (encryption.py) ---
# 256-bit master key (32 bytes) for application-level data encryption.
# Leave defaults if your app does not need encryption.
MASTER_ENCRYPTION_KEY="your_256_bit_key_here"
PERSISTENT_ENCRYPTION_SALT="your_unique_salt_here"


# =============================================================================
# SECTION 2 — Logging
# =============================================================================

# PyFundaments internal debug output (true/false)
PYFUNDAMENTS_DEBUG="true"

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL="INFO"

# Write logs to /tmp (cleared on restart) — useful for HuggingFace Spaces
LOG_TO_TMP="false"

# Enable log output to stdout (disable in production for security)
ENABLE_PUBLIC_LOGS="true"


# =============================================================================
# SECTION 3 — Universal MCP Hub (app/*)
# These keys activate tools — comment out what you don't use.
# No key = tool skipped = no crash.
# =============================================================================

# --- Hub Transport ---
# App mode: mcp | app
APP_MODE="mcp"

# Transport: stdio (local / Claude Desktop) | sse (HuggingFace / Remote)
MCP_TRANSPORT="sse"

# Server binding — PORT must be 7860 for HuggingFace Spaces!
PORT="7860"
HOST="0.0.0.0"

# HuggingFace Space URL (used as HTTP-Referer for provider API calls)
APP_URL="https://huggingface.co/spaces/YOUR_USERNAME/YOUR_SPACE"

# --- LLM Provider Keys (optional — activates LLM tools) ---
#ANTHROPIC_API_KEY="sk-ant-..."
#OPENROUTER_API_KEY="sk-or-..."
#HF_TOKEN="hf_..."
#GEMINI_API_KEY="..."
#OPENAI_API_KEY="sk-..."

# --- Search Provider Keys (optional — activates search tools) ---
#BRAVE_API_KEY="BSA..."
#TAVILY_API_KEY="tvly-..."


# =============================================================================
# SECTION 4 — App-Specific (uncomment what your app needs)
# =============================================================================

# --- Discord Bot ---
#PUBLIC_KEY="your-discord-public-key"
#APPLICATION_ID="your-discord-app-id"
#BOT_TOKEN="your-bot-token"
#GUILD_ID="your-guild-id"
#BOT_VERSION="1.0.0"
#ADMIN_USER_IDS="user1,user2,user3"

# --- GitHub / GitLab Webhooks ---
#GITHUB_TOKEN="ghp_..."
#GITLAB_TOKEN="glpat-..."
#WEBHOOK_SECRET="your-webhook-secret"

# --- ML / LLM Local ---
#MODEL_PATH="/path/to/your/model"
#MAX_TOKENS="2048"
#TEMPERATURE="0.7"
